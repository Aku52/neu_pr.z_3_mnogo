from keras.datasets import cifar10
from keras import models, layers
from keras.utils import to_categorical
import numpy as np

# Загрузка CIFAR10
(x_train, y_train), (x_test, y_test) = cifar10.load_data()

# Нормализация
x_train, x_test = x_train / 255.0, x_test / 255.0

# One-hot кодирование
y_train = to_categorical(y_train, 10)
y_test = to_categorical(y_test, 10)

# Взять случайную подвыборку (10000 изображений) - ОДНОЙ СТРОКОЙ
indices = np.random.choice(len(x_train), 10000, replace=False)
x_train_small, y_train_small = x_train[indices], y_train[indices]

print(f"Полная выборка: {len(x_train)} изображений")
print(f"Случайная выборка: {len(x_train_small)} изображений")

# Модель
model = models.Sequential([
    layers.Conv2D(32, (3,3), activation='relu', input_shape=(32,32,3)),
    layers.MaxPooling2D((2,2)),
    layers.Conv2D(64, (3,3), activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64, activation='relu'),
    layers.Dense(10, activation='softmax')
])

model.compile(
    optimizer='adam',
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

# Обучение на полной выборке
print("\n=== Обучение на полной выборке ===")
history_full = model.fit(
    x_train, 
    y_train, 
    epochs=10, 
    batch_size=64,
    validation_split=0.1,
    verbose=1
)

# Оценка на тестовой выборке
test_loss_full, test_acc_full = model.evaluate(x_test, y_test, verbose=0)
print(f"Точность на тесте (полная выборка): {test_acc_full:.4f}")

# Создаем новую модель для обучения на маленькой выборке
model_small = models.Sequential([
    layers.Conv2D(32, (3,3), activation='relu', input_shape=(32,32,3)),
    layers.MaxPooling2D((2,2)),
    layers.Conv2D(64, (3,3), activation='relu'),
    layers.MaxPooling2D((2,2)),
    layers.Flatten(),
    layers.Dense(64, activation='relu'),
    layers.Dense(10, activation='softmax')
])

model_small.compile(
    optimizer='adam',
    loss='categorical_crossentropy',
    metrics=['accuracy']
)

# Обучение на случайной выборке
print("\n=== Обучение на случайной выборке ===")
history_small = model_small.fit(
    x_train_small, 
    y_train_small, 
    epochs=10, 
    batch_size=64,
    validation_split=0.1,
    verbose=1
)

# Оценка на тестовой выборке
test_loss_small, test_acc_small = model_small.evaluate(x_test, y_test, verbose=0)
print(f"Точность на тесте (случайная выборка): {test_acc_small:.4f}")

# Сравнение результатов
print("\n=== СРАВНЕНИЕ РЕЗУЛЬТАТОВ ===")
print(f"Полная выборка: {test_acc_full:.4f}")
print(f"Случайная выборка (10000 изображений): {test_acc_small:.4f}")
print(f"Разница: {test_acc_full - test_acc_small:.4f}")